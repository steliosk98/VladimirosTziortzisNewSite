---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articles } from '../data/articles';
import { withBase } from '../lib/url';

const publisherAliases: Record<string, string> = {
  'ΑΝΤ1': 'ANT1',
  'AutoΚίνητο:': 'AutoΚίνητο',
  'CyprusMail': 'Cyprus Mail',
  'SigmaLive': 'Sigma Live',
  'SportTime / SigmaLive': 'Sigma Live',
};
const normalizePublisher = (publisher: string) => publisherAliases[publisher] ?? publisher;
const publications = Array.from(new Set(articles.map(a => normalizePublisher(a.publication)))).sort();
const articlesPerPage = 12;
const totalPages = Math.ceil(articles.length / articlesPerPage);
---
<BaseLayout
  title="Articles — Vladimiros Tziortzis"
  description="Interviews and articles featuring Vladimiros Tziortzis — from Cypriot racing press to international motorsport media."
>
  <section class="pt-[calc(var(--nav-h)+6rem)] pb-20 md:pt-[calc(var(--nav-h)+9rem)] md:pb-28 relative isolate border-b border-rule overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <img
        src={withBase('/images/spy-4222-1-2000x1333.jpg')}
        alt=""
        class="parallax-media w-full h-full object-cover object-[50%_0%] opacity-80 scale-[1.08]"
        data-parallax
        data-parallax-speed="-0.06"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-bg/85 via-bg/65 to-bg"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-bg via-bg/85 to-bg/45"></div>
      <div class="absolute inset-0 bg-bg/35"></div>
      <div class="absolute inset-0 bg-accent/15 mix-blend-multiply"></div>
    </div>

    <div class="container-site relative z-10">
      <div class="flex flex-col gap-6 max-w-3xl">
        <span class="kicker">Media Archive</span>
        <h1 class="font-display text-display-lg text-fg leading-none">Articles</h1>
        <div class="flex items-center gap-4">
          <span class="h-px w-14 bg-accent"></span>
          <p class="font-sans text-fg/85 text-sm md:text-base uppercase tracking-[0.2em]">
            Interviews & articles featuring Vladimiros
          </p>
        </div>
        <div class="flex flex-wrap items-baseline gap-6 md:gap-10 pt-6 mt-4 border-t border-rule">
          <div class="flex items-baseline gap-3">
            <span class="font-display text-4xl md:text-5xl text-accent">{articles.length}</span>
            <span class="font-sans text-xs text-fg/75 uppercase tracking-[0.25em]">Articles</span>
          </div>
          <div class="flex items-baseline gap-3">
            <span class="font-display text-4xl md:text-5xl text-accent">{publications.length}</span>
            <span class="font-sans text-xs text-fg/75 uppercase tracking-[0.25em]">Publications</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="font-article py-16 md:py-24">
    <div class="container-site">
      <div class="mb-8 md:mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="font-sans text-xs text-accent font-bold uppercase tracking-[0.28em]">Archive</p>
          <h2 class="mt-2 font-display text-4xl md:text-5xl text-fg">Latest Coverage</h2>
        </div>
        <p id="articles-page-status" class="font-sans text-xs text-fg/70 uppercase tracking-[0.22em]">
          Page 1 of {totalPages}
        </p>
      </div>

      <div class="mb-8 grid gap-4 md:grid-cols-[1fr_minmax(14rem,18rem)]">
        <label class="flex flex-col gap-2">
          <span class="font-sans text-xs text-fg/70 uppercase tracking-[0.22em]">Search articles</span>
          <input
            id="articles-search"
            type="search"
            class="input-field font-article"
            placeholder="Search by title or publisher"
            autocomplete="off"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-sans text-xs text-fg/70 uppercase tracking-[0.22em]">Publisher</span>
          <select id="articles-publisher" class="input-field font-article">
            <option value="">All publishers</option>
            {publications.map(publication => (
              <option value={publication}>{publication}</option>
            ))}
          </select>
        </label>
      </div>

      <div id="articles-list" class="article-list border-y border-rule">
        {articles.map((article, i) => (
          <a
            href={article.url}
            target="_blank"
            rel="noopener"
            class="article-row reveal group grid gap-4 md:grid-cols-[5rem_minmax(10rem,14rem)_1fr_auto] md:items-center py-5 md:py-6 border-b border-rule last:border-b-0"
            data-article-row
            data-publication={normalizePublisher(article.publication)}
            data-search={`${normalizePublisher(article.publication)} ${article.publication} ${article.title}`.toLowerCase()}
            style={`transition-delay:${(i % articlesPerPage) * 0.035}s`}
          >
            <span class="font-display text-3xl md:text-4xl text-accent/70 group-hover:text-accent transition-colors">
              {String(i + 1).padStart(2, '0')}
            </span>

            <span class="flex items-center justify-center h-12 max-w-48 w-full bg-white px-4 py-2">
              <img
                src={withBase(article.logo)}
                alt={article.publication}
                loading="lazy"
                class="max-h-8 w-auto object-contain opacity-90 group-hover:opacity-100 transition duration-300"
              />
            </span>

            <span class="flex flex-col gap-2">
              <span class="font-sans text-[11px] font-bold text-accent uppercase tracking-[0.24em]">
                {normalizePublisher(article.publication)}
              </span>
              <span class="font-article text-xl md:text-2xl font-bold text-fg leading-snug group-hover:text-accent transition-colors">
                {article.title}
              </span>
            </span>

            <span class="inline-flex items-center gap-3 font-sans text-xs text-fg/70 uppercase tracking-[0.22em] group-hover:text-accent transition-colors">
              Read
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="group-hover:translate-x-1 transition-transform">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <p id="articles-empty" class="hidden border-b border-rule py-10 text-center font-article text-fg/70">
        No articles match your search.
      </p>

      <nav class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4" aria-label="Articles pagination">
        <button type="button" id="articles-prev" class="btn-outline disabled:pointer-events-none disabled:opacity-35">
          Previous
        </button>

        <div id="articles-pagination" class="flex flex-wrap justify-center gap-2"></div>

        <button type="button" id="articles-next" class="btn-outline disabled:pointer-events-none disabled:opacity-35">
          Next
        </button>
      </nav>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ articlesPerPage }}>
  const rows = Array.from(document.querySelectorAll('[data-article-row]'));
  const pagination = document.getElementById('articles-pagination');
  const prev = document.getElementById('articles-prev');
  const next = document.getElementById('articles-next');
  const status = document.getElementById('articles-page-status');
  const search = document.getElementById('articles-search');
  const publisher = document.getElementById('articles-publisher');
  const empty = document.getElementById('articles-empty');
  let currentPage = 1;
  let activeRows = rows;

  const renderPagination = (pageCount) => {
    if (!pagination) return;
    pagination.innerHTML = '';

    for (let i = 1; i <= pageCount; i += 1) {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'article-page-btn w-11 h-11 border border-rule font-sans text-xs font-bold uppercase tracking-widest text-fg/80 hover:border-accent hover:text-accent transition-colors';
      button.dataset.pageButton = String(i);
      button.setAttribute('aria-label', `Go to articles page ${i}`);
      button.textContent = String(i);
      button.addEventListener('click', () => showPage(i));
      pagination.append(button);
    }
  };

  const showPage = (page) => {
    const pageCount = Math.max(1, Math.ceil(activeRows.length / articlesPerPage));
    currentPage = Math.min(pageCount, Math.max(1, page));
    const start = (currentPage - 1) * articlesPerPage;
    const end = start + articlesPerPage;

    rows.forEach((row) => {
      row.classList.add('hidden');
      row.classList.remove('is-visible');
    });

    activeRows.slice(start, end).forEach((row) => {
      row.classList.remove('hidden');
      requestAnimationFrame(() => row.classList.add('is-visible'));
    });

    const pageButtons = Array.from(document.querySelectorAll('[data-page-button]'));
    pageButtons.forEach((button) => {
      const isActive = Number(button.dataset.pageButton) === currentPage;
      button.classList.toggle('border-accent', isActive);
      button.classList.toggle('text-accent', isActive);
      button.setAttribute('aria-current', isActive ? 'page' : 'false');
    });

    if (prev) prev.toggleAttribute('disabled', currentPage === 1);
    if (next) next.toggleAttribute('disabled', currentPage === pageCount);
    if (status) {
      status.textContent = activeRows.length
        ? `Page ${currentPage} of ${pageCount} · ${activeRows.length} articles`
        : 'No articles found';
    }
    if (empty) empty.classList.toggle('hidden', activeRows.length > 0);
    pagination?.classList.toggle('hidden', pageCount <= 1);
  };

  const applyFilters = () => {
    const query = search?.value.trim().toLowerCase() ?? '';
    const selectedPublisher = publisher?.value ?? '';

    activeRows = rows.filter((row) => {
      const matchesSearch = !query || row.dataset.search?.includes(query);
      const matchesPublisher = !selectedPublisher || row.dataset.publication === selectedPublisher;
      return matchesSearch && matchesPublisher;
    });

    const pageCount = Math.max(1, Math.ceil(activeRows.length / articlesPerPage));
    renderPagination(pageCount);
    showPage(1);
  };

  search?.addEventListener('input', applyFilters);
  publisher?.addEventListener('change', applyFilters);
  prev?.addEventListener('click', () => showPage(currentPage - 1));
  next?.addEventListener('click', () => showPage(currentPage + 1));

  applyFilters();
</script>
