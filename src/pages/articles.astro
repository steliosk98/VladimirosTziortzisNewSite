---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articles } from '../data/articles';
import { withBase } from '../lib/url';

const publications = Array.from(new Set(articles.map(a => a.publication))).sort();
const articlesPerPage = 12;
const totalPages = Math.ceil(articles.length / articlesPerPage);
---
<BaseLayout
  title="Articles — Vladimiros Tziortzis"
  description="Interviews and articles featuring Vladimiros Tziortzis — from Cypriot racing press to international motorsport media."
>
  <section class="pt-[calc(var(--nav-h)+6rem)] pb-20 md:pt-[calc(var(--nav-h)+9rem)] md:pb-28 relative isolate border-b border-rule overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <img
        src={withBase('/images/spy-4222-1-2000x1333.jpg')}
        alt=""
        class="parallax-media w-full h-full object-cover object-[50%_0%] opacity-80 scale-[1.08]"
        data-parallax
        data-parallax-speed="-0.06"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-bg/85 via-bg/65 to-bg"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-bg via-bg/85 to-bg/45"></div>
      <div class="absolute inset-0 bg-bg/35"></div>
      <div class="absolute inset-0 bg-accent/15 mix-blend-multiply"></div>
    </div>

    <div class="container-site relative z-10">
      <div class="flex flex-col gap-6 max-w-3xl">
        <span class="kicker">Media Archive</span>
        <h1 class="font-display text-display-lg text-fg leading-none">Articles</h1>
        <div class="flex items-center gap-4">
          <span class="h-px w-14 bg-accent"></span>
          <p class="font-sans text-fg/85 text-sm md:text-base uppercase tracking-[0.2em]">
            Interviews & articles featuring Vladimiros
          </p>
        </div>
        <div class="flex flex-wrap items-baseline gap-6 md:gap-10 pt-6 mt-4 border-t border-rule">
          <div class="flex items-baseline gap-3">
            <span class="font-display text-4xl md:text-5xl text-accent">{articles.length}</span>
            <span class="font-sans text-xs text-fg/75 uppercase tracking-[0.25em]">Articles</span>
          </div>
          <div class="flex items-baseline gap-3">
            <span class="font-display text-4xl md:text-5xl text-accent">{publications.length}</span>
            <span class="font-sans text-xs text-fg/75 uppercase tracking-[0.25em]">Publications</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="font-article py-16 md:py-24">
    <div class="container-site">
      <div class="mb-8 md:mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="font-sans text-xs text-accent font-bold uppercase tracking-[0.28em]">Archive</p>
          <h2 class="mt-2 font-display text-4xl md:text-5xl text-fg">Latest Coverage</h2>
        </div>
        <p id="articles-page-status" class="font-sans text-xs text-fg/70 uppercase tracking-[0.22em]">
          Page 1 of {totalPages}
        </p>
      </div>

      <div id="articles-list" class="article-list border-y border-rule">
        {articles.map((article, i) => (
          <a
            href={article.url}
            target="_blank"
            rel="noopener"
            class="article-row reveal group grid gap-4 md:grid-cols-[5rem_minmax(10rem,14rem)_1fr_auto] md:items-center py-5 md:py-6 border-b border-rule last:border-b-0"
            data-article-row
            data-page={Math.floor(i / articlesPerPage) + 1}
            style={`transition-delay:${(i % articlesPerPage) * 0.035}s`}
          >
            <span class="font-display text-3xl md:text-4xl text-accent/70 group-hover:text-accent transition-colors">
              {String(i + 1).padStart(2, '0')}
            </span>

            <span class="flex items-center h-12 max-w-48">
              <img
                src={withBase(article.logo)}
                alt={article.publication}
                loading="lazy"
                class="max-h-10 w-auto object-contain grayscale opacity-75 group-hover:opacity-100 group-hover:grayscale-0 transition duration-300"
              />
            </span>

            <span class="flex flex-col gap-2">
              <span class="font-sans text-[11px] font-bold text-accent uppercase tracking-[0.24em]">
                {article.publication}
              </span>
              <span class="font-article text-xl md:text-2xl font-bold text-fg leading-snug group-hover:text-accent transition-colors">
                {article.title}
              </span>
            </span>

            <span class="inline-flex items-center gap-3 font-sans text-xs text-fg/70 uppercase tracking-[0.22em] group-hover:text-accent transition-colors">
              Read
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="group-hover:translate-x-1 transition-transform">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <nav class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4" aria-label="Articles pagination">
        <button type="button" id="articles-prev" class="btn-outline disabled:pointer-events-none disabled:opacity-35">
          Previous
        </button>

        <div id="articles-pagination" class="flex flex-wrap justify-center gap-2">
          {Array.from({ length: totalPages }, (_, i) => (
            <button
              type="button"
              class="article-page-btn w-11 h-11 border border-rule font-sans text-xs font-bold uppercase tracking-widest text-fg/80 hover:border-accent hover:text-accent transition-colors"
              data-page-button={i + 1}
              aria-label={`Go to articles page ${i + 1}`}
            >
              {i + 1}
            </button>
          ))}
        </div>

        <button type="button" id="articles-next" class="btn-outline disabled:pointer-events-none disabled:opacity-35">
          Next
        </button>
      </nav>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ totalPages }}>
  const rows = Array.from(document.querySelectorAll('[data-article-row]'));
  const pageButtons = Array.from(document.querySelectorAll('[data-page-button]'));
  const prev = document.getElementById('articles-prev');
  const next = document.getElementById('articles-next');
  const status = document.getElementById('articles-page-status');
  let currentPage = 1;

  const showPage = (page) => {
    currentPage = Math.min(totalPages, Math.max(1, page));

    rows.forEach((row) => {
      const isActive = Number(row.dataset.page) === currentPage;
      row.classList.toggle('hidden', !isActive);
      if (isActive) {
        row.classList.remove('is-visible');
        requestAnimationFrame(() => row.classList.add('is-visible'));
      }
    });

    pageButtons.forEach((button) => {
      const isActive = Number(button.dataset.pageButton) === currentPage;
      button.classList.toggle('border-accent', isActive);
      button.classList.toggle('text-accent', isActive);
      button.setAttribute('aria-current', isActive ? 'page' : 'false');
    });

    if (prev) prev.toggleAttribute('disabled', currentPage === 1);
    if (next) next.toggleAttribute('disabled', currentPage === totalPages);
    if (status) status.textContent = `Page ${currentPage} of ${totalPages}`;
  };

  pageButtons.forEach((button) => {
    button.addEventListener('click', () => showPage(Number(button.dataset.pageButton)));
  });
  prev?.addEventListener('click', () => showPage(currentPage - 1));
  next?.addEventListener('click', () => showPage(currentPage + 1));

  showPage(1);
</script>
