---
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  id?: string;
}
const { kicker, title, subtitle, align = 'center', id } = Astro.props;
const alignClass = align === 'center' ? 'items-center text-center' : 'items-start text-left';
---
<div id={id} class={`reveal flex flex-col gap-5 ${alignClass}`}>
  {kicker && <span class="kicker">{kicker}</span>}
  <h2 class="font-display text-display-md leading-none">{title}</h2>
  <span class="section-rule"></span>
  {subtitle && <p class="font-sans text-muted max-w-2xl text-base md:text-lg">{subtitle}</p>}
</div>
