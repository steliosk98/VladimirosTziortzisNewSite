---
import SectionHeading from './SectionHeading.astro';
import { stats } from '../data/site';
---
<section id="media" class="py-24 md:py-32">
  <div class="container-site">
    <div class="grid lg:grid-cols-[5fr_7fr] gap-14 lg:gap-20 items-center">
      <div class="flex flex-col gap-10">
        <SectionHeading kicker="In The Press" title="Media Exposure" subtitle="Numbers per year." align="left" />
        <div class="reveal relative">
          <img
            src="/images/120815639-3352525888117737-3703448797567236432-o-780x520.jpeg"
            alt="Media coverage"
            loading="lazy"
            class="w-full aspect-[3/2] object-cover border border-rule"
          />
          <div class="absolute -bottom-3 -right-3 bg-accent px-5 py-2 font-sans text-xs uppercase tracking-[0.25em] font-bold">
            On Air · On Print · On Feed
          </div>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 md:gap-5">
        {stats.map((s, i) => (
          <div class="reveal card-flat p-6 md:p-8 flex flex-col gap-3" style={`transition-delay:${i * 0.08}s`}>
            <div class="flex items-baseline justify-between gap-2 pb-4 border-b border-rule">
              <span class="counter font-display text-display-md text-accent leading-none" data-target={s.value}>0</span>
              <span class="font-sans text-xs text-muted uppercase tracking-[0.2em]">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl text-fg tracking-wide">{s.label}</h3>
            <p class="font-sans text-sm text-muted">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const format = (n: number) => n.toLocaleString('en-US');
  const animate = (el: Element) => {
    const target = Number((el as HTMLElement).dataset.target ?? 0);
    const duration = 1600;
    const start = performance.now();
    const step = (now: number) => {
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3);
      el.textContent = format(Math.round(target * eased));
      if (t < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animate(entry.target);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.counter').forEach(el => observer.observe(el));
</script>
