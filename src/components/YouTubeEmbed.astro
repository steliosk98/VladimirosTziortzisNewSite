---
import SectionHeading from './SectionHeading.astro';
import { siteMeta } from '../data/site';

const uploadsPlaylistId = siteMeta.youtubeChannelId.startsWith('UC')
  ? `UU${siteMeta.youtubeChannelId.slice(2)}`
  : siteMeta.youtubeChannelId;
const src = `https://www.youtube-nocookie.com/embed/videoseries?list=${uploadsPlaylistId}`;
---
<section class="py-24 md:py-32 border-t border-rule">
  <div class="container-site flex flex-col gap-12 items-center">
    <SectionHeading kicker="Watch" title="Latest From The Channel" align="center" />

    <div class="reveal w-full max-w-5xl aspect-video border border-rule bg-bg-elev overflow-hidden">
      <iframe
        src={src}
        title="Vladimiros Tziortzis — YouTube"
        frameborder="0"
        loading="lazy"
        allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="w-full h-full"
      ></iframe>
    </div>

    <a href={`https://www.youtube.com/channel/${siteMeta.youtubeChannelId}`} target="_blank" rel="noopener" class="btn-outline">
      Visit Channel
    </a>
  </div>
</section>
