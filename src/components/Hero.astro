---
import { withBase } from '../lib/url';
---
<section class="relative isolate min-h-screen flex items-center overflow-hidden bg-grain">
  <div class="absolute inset-0 z-0">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      src={withBase('/videos/hero.mp4')}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={withBase('/images/background-1-2000x569.jpg')}
      aria-hidden="true"
    ></video>
    <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(to bottom, rgba(10,10,10,0.4), rgba(10,10,10,0.25) 40%, rgba(10,10,10,0.95));"></div>
    <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(to right, rgba(10,10,10,0.55), rgba(10,10,10,0.1) 50%, transparent);"></div>
  </div>

  <div class="container-site relative z-10 py-32 md:py-40">
    <div class="flex flex-col gap-6 md:gap-8 max-w-5xl">
      <span class="kicker animate-fade-up" style="animation-delay:.1s">Cypriot F3 / EuroNASCAR Driver</span>

      <h1 class="font-display text-display-xl text-fg animate-fade-up" style="animation-delay:.25s">
        Vladimiros<br />Tziortzis
      </h1>

      <div class="flex items-center gap-4 animate-fade-up" style="animation-delay:.4s">
        <span class="h-px w-14 bg-accent"></span>
        <p class="font-sans font-bold text-sm md:text-base uppercase tracking-[0.3em] text-fg/90">
          Dream &middot; Determination &middot; Achievement
        </p>
      </div>

      <div class="flex flex-wrap gap-4 mt-4 animate-fade-up" style="animation-delay:.55s">
        <a href="#about" class="btn-primary">Meet The Driver</a>
        <a href="#next-race" class="btn-outline">Next Race</a>
      </div>
    </div>
  </div>

  <a href="#next-race" aria-label="Scroll down" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-muted hover:text-accent transition-colors">
    <span class="font-sans text-[10px] tracking-[0.3em] uppercase">Scroll</span>
    <svg width="14" height="24" viewBox="0 0 14 24" fill="none" stroke="currentColor" stroke-width="1.5" class="animate-bounce">
      <path d="M7 1v20M1 15l6 6 6-6"/>
    </svg>
  </a>

  <div class="absolute top-1/4 right-0 w-1 h-40 bg-accent hidden lg:block"></div>
  <div class="absolute bottom-1/4 right-8 w-1 h-20 bg-accent/50 hidden lg:block"></div>
</section>

