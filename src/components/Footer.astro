---
import { socials, siteMeta } from '../data/site';
import { withBase } from '../lib/url';
---
<footer class="border-t border-rule py-12 md:py-16">
  <div class="container-site flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-4">
      <img src={withBase('/images/vt-logo-168x168.png')} alt="VT" width="40" height="40" class="w-10 h-10" />
      <div class="flex flex-col leading-tight">
        <span class="font-display text-lg">Vladimiros Tziortzis</span>
        <span class="font-sans text-xs text-muted uppercase tracking-widest">Dream · Determination · Achievement</span>
      </div>
    </div>

    <div class="flex items-center gap-4 order-first md:order-none">
      <a href={socials.twitter} target="_blank" rel="noopener" aria-label="Twitter" class="w-9 h-9 border border-rule flex items-center justify-center hover:border-accent hover:text-accent transition-colors">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href={socials.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="w-9 h-9 border border-rule flex items-center justify-center hover:border-accent hover:text-accent transition-colors">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
      </a>
      <a href={socials.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="w-9 h-9 border border-rule flex items-center justify-center hover:border-accent hover:text-accent transition-colors">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.975.975 1.246 2.242 1.308 3.608.058 1.266.069 1.645.069 4.85 0 3.204-.012 3.584-.07 4.85-.062 1.366-.334 2.633-1.308 3.608-.975.975-2.242 1.246-3.608 1.308-1.266.058-1.645.069-4.85.069-3.204 0-3.584-.012-4.85-.07-1.366-.062-2.633-.334-3.608-1.308-.975-.975-1.246-2.242-1.308-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608C4.516 2.567 5.783 2.296 7.15 2.234 8.416 2.175 8.796 2.163 12 2.163zm0 4.865a4.972 4.972 0 110 9.944 4.972 4.972 0 010-9.944zm0 8.205a3.233 3.233 0 100-6.466 3.233 3.233 0 000 6.466zm6.406-8.404a1.163 1.163 0 11-2.326 0 1.163 1.163 0 012.326 0z"/></svg>
      </a>
      <a href={socials.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="w-9 h-9 border border-rule flex items-center justify-center hover:border-accent hover:text-accent transition-colors">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    </div>

    <div class="flex flex-col md:items-end items-center gap-1 text-xs font-sans text-muted">
      <p>© Copyright {siteMeta.copyrightYears} Vladimiros Tziortzis</p>
      <p>
        Design by{' '}
        <a href={siteMeta.designCredit.url} target="_blank" rel="noopener" class="text-fg hover:text-accent transition-colors">
          {siteMeta.designCredit.name}
        </a>
        {' · '}
        <a href={withBase('/privacy')} class="hover:text-accent transition-colors">Cookie Policy</a>
      </p>
    </div>
  </div>
</footer>
