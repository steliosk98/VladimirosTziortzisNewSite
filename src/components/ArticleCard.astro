---
import type { Article } from '../data/articles';
import { withBase } from '../lib/url';
interface Props {
  article: Article;
  index: number;
}
const { article, index } = Astro.props;
---
<a
  href={article.url}
  target="_blank"
  rel="noopener"
  class="article-card card-flat group flex flex-col gap-4 p-5 md:p-6 h-full"
>
  <div class="flex items-center justify-between gap-4 pb-4 border-b border-rule">
    <div class="flex items-center h-10 max-w-[60%]">
      <img
        src={withBase(article.logo)}
        alt={article.publication}
        loading="lazy"
        class="max-h-10 w-auto object-contain grayscale opacity-80 group-hover:opacity-100 group-hover:grayscale-0 transition duration-300"
      />
    </div>
    <span class="font-sans text-[10px] text-muted uppercase tracking-[0.25em]">
      #{String(index + 1).padStart(3, '0')}
    </span>
  </div>

  <p class="font-sans text-[11px] font-bold text-accent uppercase tracking-[0.25em]">
    {article.publication}
  </p>

  <p class="font-display text-lg md:text-xl text-fg leading-tight flex-1 tracking-wide">
    {article.title}
  </p>

  <div class="flex items-center justify-between gap-2 pt-3 border-t border-rule">
    <span class="font-sans text-xs text-muted uppercase tracking-widest">Read article</span>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted group-hover:text-accent group-hover:translate-x-1 transition-all">
      <path d="M5 12h14M13 6l6 6-6 6"/>
    </svg>
  </div>
</a>
