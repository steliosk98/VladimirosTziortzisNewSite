---
import { nav, socials } from '../data/site';
---
<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-colors">
  <div class="container-site flex items-center justify-between h-[var(--nav-h)]">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/images/vt-logo-168x168.png" alt="VT" width="40" height="40" class="w-10 h-10" />
      <span class="hidden sm:flex flex-col leading-none">
        <span class="font-display text-xl tracking-wide group-hover:text-accent transition-colors">Vladimiros Tziortzis</span>
        <span class="font-sans text-[10px] text-muted tracking-[0.2em] uppercase">Racing Driver</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {nav.map(item => (
        <a href={item.href} class="font-sans text-sm font-medium uppercase tracking-widest text-fg/80 hover:text-accent transition-colors">
          {item.label}
        </a>
      ))}
      <div class="flex items-center gap-3 pl-6 border-l border-rule">
        <a href={socials.twitter} target="_blank" rel="noopener" aria-label="Twitter" class="hover:text-accent transition-colors">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={socials.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="hover:text-accent transition-colors">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
        </a>
        <a href={socials.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="hover:text-accent transition-colors">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.975.975 1.246 2.242 1.308 3.608.058 1.266.069 1.645.069 4.85 0 3.204-.012 3.584-.07 4.85-.062 1.366-.334 2.633-1.308 3.608-.975.975-2.242 1.246-3.608 1.308-1.266.058-1.645.069-4.85.069-3.204 0-3.584-.012-4.85-.07-1.366-.062-2.633-.334-3.608-1.308-.975-.975-1.246-2.242-1.308-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608C4.516 2.567 5.783 2.296 7.15 2.234 8.416 2.175 8.796 2.163 12 2.163zm0 1.802c-3.152 0-3.505.01-4.744.067-.977.045-1.504.207-1.856.344-.466.181-.8.398-1.15.748-.35.35-.567.684-.748 1.15-.137.352-.3.88-.344 1.856-.057 1.239-.067 1.592-.067 4.744s.01 3.505.067 4.744c.045.977.207 1.504.344 1.856.181.466.398.8.748 1.15.35.35.684.567 1.15.748.352.137.88.3 1.856.344 1.239.057 1.592.067 4.744.067s3.505-.01 4.744-.067c.977-.045 1.504-.207 1.856-.344.466-.181.8-.398 1.15-.748.35-.35.567-.684.748-1.15.137-.352.3-.88.344-1.856.057-1.239.067-1.592.067-4.744s-.01-3.505-.067-4.744c-.045-.977-.207-1.504-.344-1.856a3.1 3.1 0 00-.748-1.15 3.1 3.1 0 00-1.15-.748c-.352-.137-.88-.3-1.856-.344C15.505 3.975 15.152 3.965 12 3.965zm0 3.063a4.972 4.972 0 110 9.944 4.972 4.972 0 010-9.944zm0 8.205a3.233 3.233 0 100-6.466 3.233 3.233 0 000 6.466zm6.406-8.404a1.163 1.163 0 11-2.326 0 1.163 1.163 0 012.326 0z"/></svg>
        </a>
        <a href={socials.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="hover:text-accent transition-colors">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </nav>

    <button id="mobile-menu-toggle" class="md:hidden w-10 h-10 flex items-center justify-center" aria-label="Open menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-rule bg-bg">
    <nav class="container-site flex flex-col py-6 gap-4">
      {nav.map(item => (
        <a href={item.href} class="font-sans text-base font-medium uppercase tracking-widest text-fg/90 hover:text-accent transition-colors">
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 20) nav.classList.add('nav-scrolled');
    else nav.classList.remove('nav-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.add('hidden')));
</script>
