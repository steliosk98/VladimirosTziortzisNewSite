---
import { nextRace } from '../data/site';
---
<section id="next-race" class="relative isolate py-24 md:py-32 border-y border-rule overflow-hidden">
  <img
    src="/images/background-1-2000x569.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover z-0"
  />
  <div class="absolute inset-0 z-0" style="background-color: rgba(10,10,10,0.55);"></div>
  <div class="absolute inset-0 z-0" style="background-image: linear-gradient(to bottom, rgba(10,10,10,0.4), rgba(10,10,10,0.1) 50%, rgba(10,10,10,0.9));"></div>

  <div class="speed-lines z-[1]"></div>

  <div class="container-site relative z-10">
    <div class="flex flex-col items-center gap-10 md:gap-14">
      <div class="reveal flex flex-col items-center gap-4">
        <span class="kicker">Next Race</span>
        <h2 class="font-display text-display-lg text-center">{nextRace.round}</h2>
        <span class="section-rule"></span>
      </div>

      <div class="reveal flex flex-col items-center gap-2 text-center">
        <p class="font-display text-2xl md:text-3xl text-fg">{nextRace.event}</p>
        <p class="font-sans text-muted text-sm md:text-base uppercase tracking-[0.3em]">{nextRace.date}</p>
      </div>

      <div
        id="countdown"
        class="reveal grid grid-cols-4 gap-3 md:gap-6 w-full max-w-4xl"
        data-target={nextRace.target}
      >
        <div class="card-flat p-5 md:p-8 flex flex-col items-center gap-2">
          <span id="cd-days" class="font-display text-5xl md:text-7xl lg:text-8xl text-accent leading-none">00</span>
          <span class="font-sans text-[10px] md:text-xs text-muted uppercase tracking-[0.25em]">Days</span>
        </div>
        <div class="card-flat p-5 md:p-8 flex flex-col items-center gap-2">
          <span id="cd-hours" class="font-display text-5xl md:text-7xl lg:text-8xl text-accent leading-none">00</span>
          <span class="font-sans text-[10px] md:text-xs text-muted uppercase tracking-[0.25em]">Hours</span>
        </div>
        <div class="card-flat p-5 md:p-8 flex flex-col items-center gap-2">
          <span id="cd-mins" class="font-display text-5xl md:text-7xl lg:text-8xl text-accent leading-none">00</span>
          <span class="font-sans text-[10px] md:text-xs text-muted uppercase tracking-[0.25em]">Minutes</span>
        </div>
        <div class="card-flat p-5 md:p-8 flex flex-col items-center gap-2">
          <span id="cd-secs" class="font-display text-5xl md:text-7xl lg:text-8xl text-accent leading-none">00</span>
          <span class="font-sans text-[10px] md:text-xs text-muted uppercase tracking-[0.25em]">Seconds</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.getElementById('countdown');
  if (root) {
    const target = new Date(root.dataset.target!).getTime();
    const dEl = document.getElementById('cd-days');
    const hEl = document.getElementById('cd-hours');
    const mEl = document.getElementById('cd-mins');
    const sEl = document.getElementById('cd-secs');
    const pad = (n: number) => String(Math.max(0, n)).padStart(2, '0');

    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        if (dEl) dEl.textContent = '00';
        if (hEl) hEl.textContent = '00';
        if (mEl) mEl.textContent = '00';
        if (sEl) sEl.textContent = '00';
        return;
      }
      const d = Math.floor(diff / 86_400_000);
      const h = Math.floor((diff % 86_400_000) / 3_600_000);
      const m = Math.floor((diff % 3_600_000) / 60_000);
      const s = Math.floor((diff % 60_000) / 1000);
      if (dEl) dEl.textContent = pad(d);
      if (hEl) hEl.textContent = pad(h);
      if (mEl) mEl.textContent = pad(m);
      if (sEl) sEl.textContent = pad(s);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
